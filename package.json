{
  "name": "seo-ghost",
  "version": "1.0.0",
  "description": "SEO metadata scraper con evasión de WAF/Cloudflare usando Playwright",
  "type": "module",
  "bin": {
    "seo-ghost": "dist/index.js"
  },
  "scripts": {
    "scrape": "tsx src/index.ts",
    "cli": "node dist/index.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "seo",
    "scraper",
    "playwright",
    "metadata",
    "cloudflare"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.35",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.12.1",
    "playwright": "^1.48.0",
    "yargs": "^17.7.0"
  }
}
